# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=socialcope
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/socialcope

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=dev-secret-key-change-in-prod
JWT_EXPIRY=7d

# API URLs
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost

# LLM (Local)
LLM_API_URL=http://localhost:11434
LLM_MODEL=qwen2.5-coder
LLM_TEMPERATURE=0.7

# Storage (Cloudflare R2)
R2_BUCKET=socialcope
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_PUBLIC_URL=https://r2.socialcope.example.com

# Services Configuration
NODE_ENV=development
PORT=3000

# Frontend
NEXT_PUBLIC_APP_NAME=socialCOPE
NEXT_PUBLIC_APP_VERSION=0.1.0

# Features (flags)
FEATURE_REALTIME_ENABLED=true
FEATURE_AI_ENABLED=false
FEATURE_EXPORT_ENABLED=false
FEATURE_RESPONSIVE_ENABLED=false

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Analytics
ANALYTICS_ENABLED=false

# Email (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@socialcope.example.com

# Optional: External APIs
SENTRY_DSN=
DATADOG_API_KEY=
